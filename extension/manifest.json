{
  "manifest_version": 3,
  "name": "TruthLens AI",
  "version": "1.0",
  "description": "Detects clickbait and misleading headlines using Machine Learning.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://truthlens-api-xnvw.onrender.com/*"
  ]
}